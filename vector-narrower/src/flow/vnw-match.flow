flow.id=vnw-match
flow.param.mode=match
flow.param.query.path=
flow.param.store.path=/tmp/vector-narrower.store
flow.param.emb.model=
flow.param.emb.socket=
flow.param.emb.dim=384
flow.param.ngr.max_tokens=5
flow.param.ngr.min_tokens=1
flow.param.ngr.separator= 	
flow.param.score.mode=cosine-similarity
flow.param.select.threshold=0.9
flow.param.select.mode=best-per-unit
flow.param.work.query_path=/tmp/vector-narrower.match.query.$$
flow.param.work.segments_path=/tmp/vector-narrower.match.segments.$$
flow.param.work.embeddings_path=/tmp/vector-narrower.match.embeddings.$$
flow.link=node-1

node.node-1.exec="$KC_FLOW_DIR/../bin/vnw-match-query" "<flow.param.mode>" "<flow.param.work.query_path>" "<flow.param.query.path>" "<flow.param.work.segments_path>" "<flow.param.work.embeddings_path>"
node.node-1.link=node-2

node.node-2.file=vnw-query-segment.flow
node.node-2.param.ngr.max_tokens=<flow.param.ngr.max_tokens>
node.node-2.param.ngr.min_tokens=<flow.param.ngr.min_tokens>
node.node-2.param.ngr.separator=<flow.param.ngr.separator>
node.node-2.link=node-3

node.node-3.exec="$KC_FLOW_DIR/../bin/vnw-capture" "<flow.param.work.segments_path>"
node.node-3.link=node-4

node.node-4.file=vnw-embed.flow
node.node-4.param.emb.model=<flow.param.emb.model>
node.node-4.param.emb.socket=<flow.param.emb.socket>
node.node-4.param.emb.dim=<flow.param.emb.dim>
node.node-4.link=node-5

node.node-5.exec="$KC_FLOW_DIR/../bin/vnw-capture" "<flow.param.work.embeddings_path>"
node.node-5.link=node-6

node.node-6.file=vnw-store-read.flow
node.node-6.param.mode=<flow.param.mode>
node.node-6.param.store.path=<flow.param.store.path>
node.node-6.link=node-7

node.node-7.file=vnw-score-select.flow
node.node-7.param.mode=<flow.param.mode>
node.node-7.param.emb.dim=<flow.param.emb.dim>
node.node-7.param.score.mode=<flow.param.score.mode>
node.node-7.param.select.threshold=<flow.param.select.threshold>
node.node-7.param.select.mode=<flow.param.select.mode>
node.node-7.param.work.segments_path=<flow.param.work.segments_path>
node.node-7.param.work.embeddings_path=<flow.param.work.embeddings_path>
