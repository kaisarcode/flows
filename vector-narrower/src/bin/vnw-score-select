#!/bin/bash
# vnw-score-select - Vector scoring helper.
# Summary: Scores query embeddings against stored vectors and emits selected
# matches.
#
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: GNU GPL v3.0
set -e

# Fails with one error message.
# @param $1 Error message.
# @return Exits with status 1.
fail() {
    printf "Error: %s\n" "$1" >&2
    exit 1
}

# Computes one batch of vector scores.
# @param $1 Pair stream path.
# @param $2 Score socket.
# @param $3 Score mode.
# @param $4 Vector dimension.
# @return Writes score lines to stdout.
compute_scores() {
    if [ -n "$2" ]; then
        kc-dmn --socket "$2" < "$1"
        return 0
    fi
    kc-emb --mode "$3" --dim "$4" < "$1"
}

# Selects records using one score stream.
# @param $1 Record path.
# @param $2 Score path.
# @param $3 Threshold.
# @param $4 Selection mode.
# @return Writes selected matches to stdout.
select_matches() {
    records_path="$1"
    scores_path="$2"
    threshold="$3"
    select_mode="$4"
    best_score=""
    best_text=""
    tmp_joined="$(mktemp)"

    paste "$records_path" "$scores_path" > "$tmp_joined"
    while IFS="$(printf '\t')" read -r text _vec score; do
        [ -n "$text" ] || continue
        if [ "$select_mode" = "all-above-threshold" ]; then
            if awk -v s="$score" -v t="$threshold" 'BEGIN { exit !((s + 0.0) >= (t + 0.0)) }'; then
                printf '%s\n' "$text"
            fi
        else
            if awk -v s="$score" -v t="$threshold" -v b="${best_score:-}" 'BEGIN { ok=((s + 0.0) >= (t + 0.0)); better=(b == "" || (s + 0.0) > (b + 0.0)); exit !(ok && better) }'; then
                best_score="$score"
                best_text="$text"
            fi
        fi
    done < "$tmp_joined"
    rm -f "$tmp_joined"
    if [ "$select_mode" != "all-above-threshold" ] && [ -n "$best_text" ]; then
        printf '%s\n' "$best_text"
    fi
}

# Processes one segment against one stored map snapshot.
# @param $1 Segment text.
# @param $2 Query vector.
# @param $3 Store snapshot path.
# @param $4 Score socket.
# @param $5 Vector dimension.
# @param $6 Score mode.
# @param $7 Threshold.
# @param $8 Selection mode.
# @return Writes selected matches to stdout.
process_segment() {
    _segment="$1"
    query_vec="$2"
    tmp_store="$3"
    score_socket="$4"
    dim="$5"
    score_mode="$6"
    threshold="$7"
    select_mode="$8"
    tmp_pairs="$(mktemp)"
    tmp_scores="$(mktemp)"
    tmp_records="$(mktemp)"

    while IFS= read -r record; do
        case "$record" in
            *$'\t'*)
                text="${record%%$'\t'*}"
                vec="${record#*$'\t'}"
                ;;
            *)
                continue
                ;;
        esac
        printf '%s\t%s\n' "$text" "$vec" >> "$tmp_records"
        printf '%s\n%s\n' "$query_vec" "$vec" >> "$tmp_pairs"
    done < "$tmp_store"

    if [ ! -s "$tmp_records" ]; then
        rm -f "$tmp_pairs" "$tmp_scores" "$tmp_records"
        return 0
    fi

    compute_scores "$tmp_pairs" "$score_socket" "$score_mode" "$dim" > "$tmp_scores"
    select_matches "$tmp_records" "$tmp_scores" "$threshold" "$select_mode"
    rm -f "$tmp_pairs" "$tmp_scores" "$tmp_records"
}

# Streams selected matches from one stored map snapshot.
# @param $1 Store snapshot path.
# @param $2 Score socket.
# @param $3 Segments path.
# @param $4 Embeddings path.
# @param $5 Vector dimension.
# @param $6 Score mode.
# @param $7 Threshold.
# @param $8 Selection mode.
# @return 0 on success.
stream_selected_matches() {
    tmp_store="$1"
    score_socket="$2"
    segments_path="$3"
    embeddings_path="$4"
    dim="$5"
    score_mode="$6"
    threshold="$7"
    select_mode="$8"

    paste "$segments_path" "$embeddings_path" | while IFS="$(printf '\t')" read -r segment query_vec; do
        [ -n "$segment" ] || continue
        process_segment "$segment" "$query_vec" "$tmp_store" "$score_socket" "$dim" \
            "$score_mode" "$threshold" "$select_mode"
    done > "/proc/self/fd/${KC_FLOW_FD_OUT}"
}

# Runs the helper entry point.
# @return 0 on success.
main() {
    [ "$#" -eq 8 ] || fail "mode, score config, and work paths are required."
    if [ "$1" != "match" ]; then
        : > "/proc/self/fd/${KC_FLOW_FD_OUT}"
        return 0
    fi
    tmp_store="$(mktemp)"
    trap 'rm -f "$tmp_store"' EXIT
    cat "/proc/self/fd/${KC_FLOW_FD_IN}" > "$tmp_store"
    stream_selected_matches "$tmp_store" "$2" "$7" "$8" "$3" "$4" "$5" "$6"
}

main "$@"
